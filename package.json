// Upload Excel demand
app.post('/api/demandes/upload', upload.single('file'), (req, res) => {
  try {
    const { semaine_debut, semaine_fin } = req.body;
    const lignes = parseDemandExcel(req.file.buffer);

    const demandeResult = db.prepare(`
      INSERT INTO demandes (semaine_debut, semaine_fin, fichier_nom, statut)
      VALUES (?, ?, ?, 'en_cours')
    `).run(semaine_debut, semaine_fin, req.file.originalname);

    const demandeId = demandeResult.lastInsertRowid;

    const insertLigne = db.prepare(`
      INSERT INTO demande_lignes (demande_id, date, evenement, role, quantite, heure_debut, heure_fin, commentaires, groupe_equipe, ordre)
      VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
    `);

    const insertMany = db.transaction((lignes) => {
      for (const l of lignes) {
        insertLigne.run(demandeId, l.date, l.evenement, l.role, l.quantite,
          l.heure_debut, l.heure_fin, l.commentaires, l.groupe_equipe, l.ordre);
      }
    });
    insertMany(lignes);

    res.json({ id: demandeId, lignes_count: lignes.length, lignes });
  } catch (err) {
    res.status(500).json({ error: err.message });
  }
});

