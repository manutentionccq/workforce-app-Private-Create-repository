});

// Generate schedule from demand
app.post('/api/horaires/generate', (req, res) => {
  try {
    const { demande_id } = req.body;
    const demande = db.prepare('SELECT * FROM demandes WHERE id = ?').get(demande_id);
    if (!demande) return res.status(404).json({ error: 'Demande non trouvée' });

    const lignes = db.prepare('SELECT * FROM demande_lignes WHERE demande_id = ? ORDER BY date, ordre').all(demande_id);
    const employees = db.prepare('SELECT * FROM employees WHERE statut = ?').all('actif');
    const disponibilites = db.prepare('SELECT * FROM disponibilites WHERE semaine_debut = ?').all(demande.semaine_debut);

    const { assignments, warnings, empHoursSummary } = generateSchedule(lignes, employees, disponibilites);

    // Clear existing horaires for this demande
    db.prepare('DELETE FROM horaires WHERE demande_id = ?').run(demande_id);

    // Insert new ones
    const insertH = db.prepare(`
      INSERT INTO horaires (demande_id, demande_ligne_id, employee_id, date, evenement, role, heure_debut, heure_fin, heures_total, commentaires, statut)
      VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, 'prevu')
    `);
    const insertAll = db.transaction((assignments) => {
      for (const a of assignments) {
        insertH.run(demande_id, a.demande_ligne_id||null, a.employee_id, a.date, a.evenement, a.role, a.heure_debut, a.heure_fin, a.heures_total, a.commentaires||'');
      }
    });
    insertAll(assignments);

    // Update demande status
    db.prepare("UPDATE demandes SET statut='complete' WHERE id=?").run(demande_id);

    res.json({ assignments, warnings, empHoursSummary, count: assignments.length });
  } catch (err) {
    res.status(500).json({ error: err.message });
  }
});

// Export schedule as Excel
app.get('/api/horaires/export/:demande_id', (req, res) => {
  try {
    const demande_id = req.params.demande_id;
    const rows = db.prepare(`
      SELECT h.date, h.evenement, h.role, e.prenom, e.nom,
             h.heure_debut, h.heure_fin, h.heures_total, h.commentaires, h.statut
      FROM horaires h
      JOIN employees e ON e.id = h.employee_id
      WHERE h.demande_id = ?
      ORDER BY h.date, h.heure_debut, e.nom
    `).all(demande_id);

    const wsData = [
      ['Date', 'Événement', 'Rôle', 'Prénom', 'Nom', 'Début', 'Fin', 'Heures', 'Commentaires', 'Statut'],
      ...rows.map(r => [r.date, r.evenement, r.role, r.prenom, r.nom, r.heure_debut, r.heure_fin, r.heures_total, r.commentaires, r.statut])
    ];

    const wb = XLSX.utils.book_new();
    const ws = XLSX.utils.aoa_to_sheet(wsData);
    ws['!cols'] = [10,14,10,12,15,8,8,8,25,10].map(w => ({ wch: w }));
    XLSX.utils.book_append_sheet(wb, ws, 'Horaire');

    // Employee summary sheet
    const empRows = db.prepare(`
      SELECT e.prenom, e.nom, SUM(h.heures_total) as total_heures, COUNT(*) as nb_shifts
      FROM horaires h
      JOIN employees e ON e.id = h.employee_id
      WHERE h.demande_id = ?
      GROUP BY h.employee_id
      ORDER BY e.nom
    `).all(demande_id);

    const summaryData = [
      ['Prénom', 'Nom', 'Total heures', 'Nb shifts', 'Heures supp (>40h)'],
      ...empRows.map(r => [r.prenom, r.nom, r.total_heures, r.nb_shifts, Math.max(0, r.total_heures - 40)])
    ];
    XLSX.utils.book_append_sheet(wb, XLSX.utils.aoa_to_sheet(summaryData), 'Résumé employés');

    const buffer = XLSX.write(wb, { type: 'buffer', bookType: 'xlsx' });
    res.setHeader('Content-Disposition', `attachment; filename="horaire_${demande_id}.xlsx"`);
    res.setHeader('Content-Type', 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet');
    res.send(buffer);
  } catch (err) {
    res.status(500).json({ error: err.message });
  }
});

