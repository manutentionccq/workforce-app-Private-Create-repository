// Send availability form to all active employees
app.post('/api/emails/send-availability', async (req, res) => {
  try {
    const { weekLabel, formUrl, employeeIds } = req.body;
    let employees;
    if (employeeIds && employeeIds.length > 0) {
      employees = db.prepare(`SELECT * FROM employees WHERE id IN (${employeeIds.map(() => '?').join(',')}) AND email IS NOT NULL`).all(...employeeIds);
    } else {
      employees = db.prepare("SELECT * FROM employees WHERE statut='actif' AND email IS NOT NULL").all();
    }
    const results = await sendAvailabilityRequest(employees, weekLabel, formUrl);
    res.json({ results, sent: results.filter(r => r.statut === 'envoye').length });
  } catch (err) {
    res.status(500).json({ error: err.message });
  }
});

// Send schedules to all assigned employees
app.post('/api/emails/send-schedules', async (req, res) => {
  try {
    const { demande_id, weekLabel } = req.body;
    const demande = db.prepare('SELECT * FROM demandes WHERE id = ?').get(demande_id);

    const assignedEmployees = db.prepare(`
      SELECT DISTINCT e.* FROM horaires h
      JOIN employees e ON e.id = h.employee_id
      WHERE h.demande_id = ? AND e.email IS NOT NULL
    `).all(demande_id);

    const allAssignments = db.prepare('SELECT * FROM horaires WHERE demande_id = ?').all(demande_id);

    const results = [];
    for (const emp of assignedEmployees) {
      const empAssignments = allAssignments.filter(a => a.employee_id === emp.id);
      const scheduleInfo = generateEmployeeScheduleText(
        { id: emp.id, prenom: emp.prenom, nom: emp.nom },
        empAssignments.map(a => ({ ...a, employee_id: a.employee_id })),
        weekLabel
      );
      if (!scheduleInfo) continue;

      const result = await sendScheduleToEmployee(emp, scheduleInfo.text, weekLabel);
      results.push({ employee: `${emp.prenom} ${emp.nom}`, ...result });

      // Mark as notified
      db.prepare('UPDATE horaires SET notifie=1 WHERE demande_id=? AND employee_id=?').run(demande_id, emp.id);
    }

    res.json({ results, sent: results.filter(r => r.statut === 'envoye').length });
  } catch (err) {
    res.status(500).json({ error: err.message });
  }
});

