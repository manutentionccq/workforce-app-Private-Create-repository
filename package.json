  res.json({ message: 'Employé désactivé' });
});

// Import employees from Excel
app.post('/api/employees/import', upload.single('file'), (req, res) => {
  try {
    const wb = XLSX.read(req.file.buffer, { type: 'buffer' });
    const ws = wb.Sheets[wb.SheetNames[0]];
    const rows = XLSX.utils.sheet_to_json(ws, { header: 1, defval: null });

    let imported = 0;
    const headerRow = 2; // 0-indexed row 2 = headers
    const dataStart = headerRow + 1;

    for (let i = dataStart; i < rows.length; i++) {
      const row = rows[i];
      if (!row[1]) continue; // skip if no name

      const fullName = String(row[1]).trim();
      if (!fullName || fullName === 'nan') continue;

      // Split name (assume "Prénom Nom" or just "Nom")
      const parts = fullName.replace(' 35h','').replace('Maternité','').split(' ');
      const prenom = parts[0] || '';
      const nom = parts.slice(1).join(' ') || '';

      const isMaternite = fullName.includes('Maternité') || fullName.toLowerCase().includes('maternit');
      const is35h = fullName.includes('35h');

      const skillCheck = (col) => {
        const val = row[col];
        return val && String(val).trim().toUpperCase() === 'X' ? 1 : 0;
      };

      try {
        db.prepare(`
          INSERT OR IGNORE INTO employees
            (nom, prenom, statut, heures_garanties, chargé_projet, chef_equipe, sous_chef, chef_elec,
             chef_quai, trafic, cariste, skyjack, manut, rideaux)
          VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?)
        `).run(
          nom, prenom,
          isMaternite ? 'maternite' : 'actif',
          is35h ? 35 : 0,
          skillCheck(2), skillCheck(3), skillCheck(4), skillCheck(5),
          skillCheck(6), skillCheck(7), skillCheck(8), skillCheck(9),
          skillCheck(10), skillCheck(11)
        );
        imported++;
      } catch {}
    }

    res.json({ imported, message: `${imported} employés importés` });
  } catch (err) {
    res.status(500).json({ error: err.message });
  }
});

