// DASHBOARD
// ─────────────────────────────────────────────

app.get('/api/dashboard', (req, res) => {
  const { semaine } = req.query;

  const totalEmployees = db.prepare("SELECT COUNT(*) as n FROM employees WHERE statut='actif'").get().n;
  const totalDemandes = db.prepare("SELECT COUNT(*) as n FROM demandes").get().n;

  let demandeQuery = 'SELECT * FROM demandes';
  if (semaine) demandeQuery += ' WHERE semaine_debut = ?';
  const demandes = semaine ? db.prepare(demandeQuery).all(semaine) : db.prepare(demandeQuery).all();

  const demandeIds = demandes.map(d => d.id);
  let coverage = { demanded: 0, covered: 0, missing: 0 };
  let overtime = [];

  if (demandeIds.length > 0) {
    const qs = demandeIds.map(() => '?').join(',');
    const demanded = db.prepare(`SELECT SUM(quantite) as n FROM demande_lignes WHERE demande_id IN (${qs})`).get(...demandeIds)?.n || 0;
    const covered = db.prepare(`SELECT COUNT(*) as n FROM horaires WHERE demande_id IN (${qs})`).get(...demandeIds)?.n || 0;
    coverage = { demanded, covered, missing: Math.max(0, demanded - covered) };

    overtime = db.prepare(`
      SELECT e.prenom, e.nom, SUM(h.heures_total) as total
      FROM horaires h
      JOIN employees e ON e.id = h.employee_id
      WHERE h.demande_id IN (${qs})
      GROUP BY h.employee_id HAVING total > 40
    `).all(...demandeIds);
  }

  const recentEmails = db.prepare("SELECT COUNT(*) as n FROM email_log WHERE statut='envoye' AND date(sent_at) >= date('now', '-7 days')").get().n;
  const pendingDispos = db.prepare("SELECT COUNT(DISTINCT e.id) as n FROM employees e WHERE e.statut='actif' AND e.id NOT IN (SELECT employee_id FROM disponibilites WHERE semaine_debut = date('now', 'weekday 0', '-6 days'))").get().n;

  res.json({
    totalEmployees,
    totalDemandes,
    coverage,
    overtime,
    recentEmails,
    pendingDispos,
    demandes: demandes.slice(0, 5),
  });
});

